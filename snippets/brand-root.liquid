{% comment %}
  brand-root.liquid
  Reusable principle block - include everywhere for consistency
  Use: {% render 'brand-root' %}
{% endcomment %}

<div class="brand-root {{ class | default: '' }}">
  <div class="brand-principle">
    <p class="principle-statement">
      The right to speak openly is the foundation of clear thinking and American liberty.<br>
      <span class="sub">Libertas Loqui exists so every independent thinker, entrepreneur, and veteran can wear the principle without fear—calmly, confidently, and with intellectual courage.</span>
    </p>
    
    <p class="mission">
      We make apparel that reminds the wearer: ideas improve when they are tested in open dialogue.<br>
      No slogans that divide. Only the quiet declaration that freedom of speech belongs to everyone who values truth over comfort.
    </p>
  </div>

  <div class="trust-bar">
    <span class="trust-item">🇺🇸 First Amendment Protected</span>
    <span class="trust-item">USA-made on premium Bayside blanks</span>
    <span class="trust-item">Free replacement on defects</span>
  </div>
</div>

<style>
  .brand-root { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; max-width: 720px; margin: 0 auto; text-align: center; }
  .principle-statement { font-size: 1.125rem; line-height: 1.6; color: var(--color-text, #111827); margin-bottom: 1rem; }
  .sub { font-size: 0.95rem; color: #4b5563; font-weight: 400; }
  .mission { font-size: 0.95rem; color: #374151; margin-bottom: 1.5rem; line-height: 1.7; }
  .trust-bar { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 2rem; font-size: 0.875rem; color: #6b7280; border-top: 1px solid #e5e7eb; padding-top: 1rem; margin-top: 1.5rem; }
  .trust-item { white-space: nowrap; }
</style>
