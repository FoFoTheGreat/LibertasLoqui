{% comment %} Free Shipping Bar – always visible, $0 threshold, Charter-compliant {% endcomment %}
<div class="free-shipping-bar">
  <div class="free-shipping-bar__inner">
    <span class="free-shipping-bar__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path d="M12 2C9.5 2 7.5 4 7.5 6.5c0 1.5.7 2.8 1.8 3.7L12 22l2.7-11.8c1.1-.9 1.8-2.2 1.8-3.7C16.5 4 14.5 2 12 2zm0 6.5c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>
      </svg>
    </span>
    <p class="free-shipping-bar__message">
      Free shipping on every order &nbsp;·&nbsp; USA-made on Bayside blanks
    </p>
  </div>
  <div class="free-shipping-bar__progress" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
    <div class="free-shipping-bar__fill"></div>
  </div>
  <p class="free-shipping-bar__status">✓ Free shipping unlocked on this order</p>
</div>
