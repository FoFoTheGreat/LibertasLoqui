{% doc %}
  @prompt
    Generate ONLY the Testimonials section for Libertas Loqui as a clean Shopify Liquid section file with schema. Brand: calm intellectual courage, strictly non-partisan, monochrome black/white/gray only, extreme negative space.REQUIREMENTS:- Section heading (exact): "What People Are Saying"- 4 testimonial cards in a clean CSS grid (2x2 on desktop, 1 column on mobile) — no JS, no masonry- Each card contains:  - Engraving-style avatar: inline SVG head silhouette (simple classical profile outline, stroke-only, no fill, ~56px). Each of the 4 avatars should be subtly distinct (slight variation in head/shoulder outline). NO photos, NO realistic faces.  - Pull quote: short 1–2 sentence customer quote in elegant serif, large enough to read as a statement  - Attribution: customer first name   city, small caps or small sans-serif, below the quote- Card style: white background, black text, generous internal padding, thin 1px black top border only (no box shadows, no full borders)- No star ratings, no review app widgets — pure typographic testimonials- Schema settings: section_heading (text), and for each of 4 testimonials: quote (textarea), name (text), location (text)- Subtle CSS hover: very slight background shift to 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 120px 40px;
    background-color: #ffffff;
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: 32px;
    letter-spacing: 0.02em;
    text-align: center;
    margin: 0 0 80px;
    color: #000000;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 60px 40px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    padding: 48px 40px;
    border-top: 1px solid #000000;
    transition: background-color 0.3s ease;
  }

  .ai-testimonial-card-{{ ai_gen_id }}:hover {
    background-color: #fafafa;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} {
    width: 56px;
    height: 56px;
    margin: 0 0 32px;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: #000000;
    fill: none;
    stroke-width: 1.5;
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};
    font-weight: {{ block.settings.quote_font.weight }};
    font-style: {{ block.settings.quote_font.style }};
    font-size: 20px;
    line-height: 1.6;
    color: #000000;
    margin: 0 0 24px;
  }

  .ai-testimonial-attribution-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #666666;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-{{ ai_gen_id }} {
      padding: 80px 20px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin: 0 0 60px;
    }

    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      padding: 36px 24px;
    }

    .ai-testimonial-quote-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }
{% endstyle %}

<div class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign name_key = 'testimonial_' | append: i | append: '_name'
          assign location_key = 'testimonial_' | append: i | append: '_location'

          assign quote = block.settings[quote_key]
          assign name = block.settings[name_key]
          assign location = block.settings[location_key]
        %}

        <div class="ai-testimonial-card-{{ ai_gen_id }}">
          <div class="ai-testimonial-avatar-{{ ai_gen_id }}">
            {% case i %}
              {% when 1 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56">
                  <path d="M28 8c-6 0-11 5-11 11v8c0 3 2 5 5 5h4c2 0 4-2 4-4v-6c0-2-2-4-4-4h-2c0-4 3-7 7-7 1 0 2-1 2-2s-1-1-2-1c-1 0-2 0-3 0z"/>
                  <path d="M18 32c0 8 6 14 14 14s14-6 14-14"/>
                  <ellipse cx="28" cy="19" rx="10" ry="12"/>
                </svg>
              {% when 2 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56">
                  <path d="M28 10c-5 0-9 4-9 9v6c0 3 2 5 5 5h3c2 0 3-1 3-3v-5c0-2-1-3-3-3h-1c0-3 2-6 6-6 1 0 1-1 1-2s0-1-1-1c-1 0-2 0-4 0z"/>
                  <path d="M20 31c0 7 5 13 12 13s12-6 12-13"/>
                  <ellipse cx="28" cy="20" rx="9" ry="11"/>
                  <path d="M22 30c1 2 3 4 6 4s5-2 6-4"/>
                </svg>
              {% when 3 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56">
                  <path d="M28 9c-5.5 0-10 4.5-10 10v7c0 2.5 2 4.5 4.5 4.5h3.5c1.5 0 3-1.5 3-3v-5.5c0-1.5-1.5-3-3-3h-1.5c0-3.5 2.5-6.5 6.5-6.5 0.5 0 1-0.5 1-1s-0.5-1-1-1c-1 0-1.5 0-2.5 0z"/>
                  <path d="M19 31c0 7.5 5.5 13.5 13 13.5s13-6 13-13.5"/>
                  <ellipse cx="28" cy="19.5" rx="9.5" ry="11.5"/>
                  <path d="M23 29c0.5 1.5 2 3 5 3s4.5-1.5 5-3"/>
                </svg>
              {% when 4 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56">
                  <path d="M28 7c-6.5 0-11.5 5.5-11.5 11.5v8.5c0 3 2.5 5.5 5.5 5.5h4.5c2 0 4-2 4-4v-6.5c0-2-2-4-4-4h-2.5c0-4 3.5-7.5 7.5-7.5 1 0 1.5-1 1.5-1.5s-0.5-1.5-1.5-1.5c-1 0-2 0-3.5 0z"/>
                  <path d="M17 33c0 8.5 6.5 15 15 15s15-6.5 15-15"/>
                  <ellipse cx="28" cy="18.5" rx="10.5" ry="12.5"/>
                  <path d="M21 31c1 2.5 4 5 7 5s6-2.5 7-5"/>
                </svg>
            {% endcase %}
          </div>

          {% if quote != blank %}
            <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ quote }}</p>
          {% endif %}

          {% if name != blank or location != blank %}
            <p class="ai-testimonial-attribution-{{ ai_gen_id }}">
              {% if name != blank %}{{ name }}{% endif %}{% if name != blank and location != blank %} • {% endif %}{% if location != blank %}{{ location }}{% endif %}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "What People Are Saying"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n4"
    },
    {
      "type": "font_picker",
      "id": "quote_font",
      "label": "Quote font",
      "default": "serif"
    },
    {
      "type": "header",
      "content": "Testimonial 1"
    },
    {
      "type": "textarea",
      "id": "testimonial_1_quote",
      "label": "Quote",
      "default": "The quality and craftsmanship are exceptional. These pieces speak to principles that matter."
    },
    {
      "type": "text",
      "id": "testimonial_1_name",
      "label": "Name",
      "default": "Sarah"
    },
    {
      "type": "text",
      "id": "testimonial_1_location",
      "label": "Location",
      "default": "Boston"
    },
    {
      "type": "header",
      "content": "Testimonial 2"
    },
    {
      "type": "textarea",
      "id": "testimonial_2_quote",
      "label": "Quote",
      "default": "Finally, apparel that stands for something timeless. Proud to wear these values."
    },
    {
      "type": "text",
      "id": "testimonial_2_name",
      "label": "Name",
      "default": "Michael"
    },
    {
      "type": "text",
      "id": "testimonial_2_location",
      "label": "Location",
      "default": "Austin"
    },
    {
      "type": "header",
      "content": "Testimonial 3"
    },
    {
      "type": "textarea",
      "id": "testimonial_3_quote",
      "label": "Quote",
      "default": "Beautifully made in America. The attention to detail and message are both outstanding."
    },
    {
      "type": "text",
      "id": "testimonial_3_name",
      "label": "Name",
      "default": "Jennifer"
    },
    {
      "type": "text",
      "id": "testimonial_3_location",
      "label": "Location",
      "default": "Portland"
    },
    {
      "type": "header",
      "content": "Testimonial 4"
    },
    {
      "type": "textarea",
      "id": "testimonial_4_quote",
      "label": "Quote",
      "default": "This is more than clothing. It's a statement of conviction and a commitment to free expression."
    },
    {
      "type": "text",
      "id": "testimonial_4_name",
      "label": "Name",
      "default": "David"
    },
    {
      "type": "text",
      "id": "testimonial_4_location",
      "label": "Location",
      "default": "Chicago"
    }
  ],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
