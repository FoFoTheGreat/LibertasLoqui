{% doc %}
  @prompt
    Create a newsletter email capture section for Libertas Loqui, a First Amendment apparel brand. Brand voice: calm confidence, sharp intellect, bold but not loud.
    
    SPECS:
    - Section headline: 'Stay in the Conversation.' in large bold sans-serif (Inter or DM Sans)
    - Subheadline below: 'Weekly principles, no spam.' in lighter weight
    - Single email input field with placeholder text: 'Your email address'
    - Submit button with label: 'Join the Conversation' — high contrast (dark button, white text or inverse)
    - Fine print below button: 'We respect your inbox as much as your rights.'
    - Minimal, high-contrast design — dark background (near black) with white text, or white background with black text
    - Centered layout, generous padding and whitespace
    - Connects to Shopify's native email capture / customer newsletter signup
    - Mobile-first responsive, no heavy scripts or libraries
    - Output as a ready-to-insert Shopify Liquid theme section, i can read the first two txt lines but everything underneath is too faint to read, its giving a liquid error below weekly principles
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-newsletter-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-newsletter-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    letter-spacing: -0.02em;
  }

  .ai-newsletter-subheadline-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.subheadline_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.form_spacing }}px;
  }

  .ai-newsletter-form-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
  }

  .ai-newsletter-form-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.input_button_gap }}px;
    margin-bottom: {{ block.settings.fine_print_spacing }}px;
  }

  .ai-newsletter-input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.input_padding }}px {{ block.settings.input_padding | times: 1.5 }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    outline: none;
  }

  .ai-newsletter-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
    opacity: 0.6;
  }

  .ai-newsletter-input-{{ ai_gen_id }}:focus {
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-newsletter-button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_background }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .ai-newsletter-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-newsletter-fine-print-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.fine_print_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-newsletter-message-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.input_font_size }}px;
    margin-top: {{ block.settings.fine_print_spacing }}px;
    padding: {{ block.settings.input_padding }}px;
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .ai-newsletter-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_text_color }};
    background-color: {{ block.settings.success_background }};
  }

  .ai-newsletter-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_text_color }};
    background-color: {{ block.settings.error_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-newsletter-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-newsletter-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }

    .ai-newsletter-form-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.input_button_gap | times: 0.8 }}px;
    }

    .ai-newsletter-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<newsletter-signup-{{ ai_gen_id }} class="ai-newsletter-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-newsletter-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-newsletter-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-newsletter-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
    {% endif %}

    <div class="ai-newsletter-form-wrapper-{{ ai_gen_id }}">
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        <div class="ai-newsletter-form-{{ ai_gen_id }}">
          <input
            type="email"
            name="contact[email]"
            class="ai-newsletter-input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-newsletter-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-newsletter-success-{{ ai_gen_id }}"
            {% endif %}
            placeholder="{{ block.settings.input_placeholder }}"
            required
          >
          <button
            type="submit"
            class="ai-newsletter-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </button>
        </div>

        {% if block.settings.fine_print != blank %}
          <p class="ai-newsletter-fine-print-{{ ai_gen_id }}">{{ block.settings.fine_print }}</p>
        {% endif %}

        {%- if form.errors -%}
          <div
            id="ai-newsletter-error-{{ ai_gen_id }}"
            class="ai-newsletter-message-{{ ai_gen_id }} ai-newsletter-error-{{ ai_gen_id }}"
          >
            {{ form.errors.messages.email }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div
            id="ai-newsletter-success-{{ ai_gen_id }}"
            class="ai-newsletter-message-{{ ai_gen_id }} ai-newsletter-success-{{ ai_gen_id }}"
          >
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</newsletter-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form) {
          form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const emailInput = this.querySelector('input[type="email"]');
        if (emailInput && !emailInput.value.trim()) {
          event.preventDefault();
        }
      }
    }

    customElements.define('newsletter-signup-{{ ai_gen_id }}', NewsletterSignup{{ ai_gen_id }});
  })();
</script>

