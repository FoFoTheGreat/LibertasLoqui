{% doc %}
  @prompt
    Create a Hero section for Libertas Loqui with the following specs:
    
    Headline: "Speech Is the First Freedom" (large, bold, high-contrast black, centered)
    Subheadline: "Wear the Principle" (elegant, centered, below headline)
    Micro trust line: "Made in USA • First Amendment Protected" (very small, light gray, directly under subheadline)
    
    Background: clean off-white #F8F7F4 or pure white. A single extremely thin vertical line centered in the hero running full height — pure black or deep charcoal (#1a1a1a), stroke-width 2-3px, 20-30% opacity. No flame, no scroll, no extra elements — just one clean straight vertical line with maximum negative space on both sides.
    
    Text layering: headline large bold centered above the line. Subheadline elegant below headline. Micro trust line in very small light gray text directly under subheadline.
    
    Add only subtle native CSS fade-in on scroll for the entire text block using CSS @keyframes and IntersectionObserver-free approach (CSS animation-play-state or scroll-driven animations if supported, otherwise a simple CSS animation on load). All code must be lightweight native Shopify Liquid + CSS only — no JavaScript libraries. Output clean Liquid + schema code only. The vertical line should be simple and engraving-style so it renders cleanly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height }}vh;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.hero_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
  }

  .ai-hero-vertical-line-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: {{ block.settings.line_width }}px;
    height: 100%;
    background-color: {{ block.settings.line_color }};
    opacity: {{ block.settings.line_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    opacity: 0;
    animation: ai-hero-fade-in-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-out forwards;
    animation-delay: {{ block.settings.animation_delay }}s;
  }

  @keyframes ai-hero-fade-in-{{ ai_gen_id }} {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .ai-hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    font-weight: {{ block.settings.subheadline_weight }};
    color: {{ block.settings.subheadline_color }};
    margin: 0 0 {{ block.settings.subheadline_spacing }}px 0;
    line-height: 1.4;
    letter-spacing: 0.02em;
  }

  .ai-hero-trust-line-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_line_size }}px;
    font-weight: {{ block.settings.trust_line_weight }};
    color: {{ block.settings.trust_line_color }};
    margin: 0;
    line-height: 1.5;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-container-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}vh;
      padding: 40px 20px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.7 }}px;
    }

    .ai-hero-trust-line-{{ ai_gen_id }} {
      font-size: {{ block.settings.trust_line_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<libertas-hero-{{ ai_gen_id }} class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-vertical-line-{{ ai_gen_id }}"></div>
    
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
      {% endif %}
      
      {% if block.settings.subheadline != blank %}
        <p class="ai-hero-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
      {% endif %}
      
      {% if block.settings.trust_line != blank %}
        <p class="ai-hero-trust-line-{{ ai_gen_id }}">{{ block.settings.trust_line }}</p>
      {% endif %}
    </div>
  </div>
</libertas-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class LibertasHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('libertas-hero-{{ ai_gen_id }}', LibertasHero{{ ai_gen_id }});
  })();
</script>

