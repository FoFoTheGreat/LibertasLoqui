{% doc %}
  @prompt
    Update ONLY the Hero section for Libertas Loqui.
    
    Headline: Speech Is the First Freedom
    Subheadline: Wear the Principle
    Micro trust line (smallest font, directly under subheadline): Made in USA • First Amendment Protected
    
    Background requirements:
    - Single, extremely thin vertical line centered in the hero, running full height — exactly like the thin divider in the Libertas Loqui logo.
    - Pure black or deep charcoal (#1a1a1a), stroke-width 2-3px, 20-30% opacity.
    - No flame, no scroll, no extra elements — just one clean, straight vertical line with maximum negative space on both sides.
    - Hero background color: clean off-white #F8F7F4 or pure white.
    - Text layering: Headline large, bold, high-contrast black centered above the line. Subheadline elegant below headline. Micro trust line in very small light gray text directly under the subheadline.
    - Add only subtle native CSS fade-in on scroll for the entire text block using CSS animation only — no JavaScript.
    - All code must be lightweight native Shopify CSS only — no JavaScript.
    
    Keep the vertical line simple and engraving-style so it renders cleanly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height }}vh;
    background-color: {{ block.settings.background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-divider-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: {{ block.settings.divider_width }}px;
    height: 100%;
    background-color: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 0 20px;
    opacity: 0;
    animation: ai-hero-fade-in-{{ ai_gen_id }} {{ block.settings.fade_duration }}s ease-out forwards;
    animation-delay: {{ block.settings.fade_delay }}s;
  }

  @keyframes ai-hero-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px 0;
    line-height: 1.1;
    letter-spacing: {{ block.settings.headline_letter_spacing }}em;
  }

  .ai-hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    font-weight: {{ block.settings.subheadline_weight }};
    color: {{ block.settings.subheadline_color }};
    margin: 0 0 {{ block.settings.subheadline_spacing }}px 0;
    line-height: 1.4;
    letter-spacing: {{ block.settings.subheadline_letter_spacing }}em;
  }

  .ai-hero-trust-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_size }}px;
    font-weight: {{ block.settings.trust_weight }};
    color: {{ block.settings.trust_color }};
    margin: 0;
    line-height: 1.5;
    letter-spacing: {{ block.settings.trust_letter_spacing }}em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}vh;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.7 }}px;
    }

    .ai-hero-trust-{{ ai_gen_id }} {
      font-size: {{ block.settings.trust_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-divider-{{ ai_gen_id }}"></div>
  
  <div class="ai-hero-content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}
    
    {% if block.settings.subheadline != blank %}
      <p class="ai-hero-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
    {% endif %}
    
    {% if block.settings.trust_line != blank %}
      <p class="ai-hero-trust-{{ ai_gen_id }}">{{ block.settings.trust_line }}</p>
    {% endif %}
  </div>
</div>

