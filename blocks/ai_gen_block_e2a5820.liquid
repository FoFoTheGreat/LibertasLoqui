{% doc %}
  @prompt
    Generate ONLY the "Why Speech Is the Most Important Right" section for Libertas Loqui as a clean Shopify Liquid section file with schema. Brand: calm intellectual courage, strictly non-partisan, monochrome black/white/gray only, extreme negative space.
    
    REQUIREMENTS:
    - Section heading (exact): "Why Speech Is the Most Important Right"
    - 3 cards in a clean CSS flex or grid row (no masonry, no JS libraries), each card contains:
     1. Card 1 — Icon: inline SVG engraving-style pamphlet/open book (fine stroke lines, no fill, lightweight). Title (exact): "It Started With a Pamphlet". Body: short 1–2 sentence copy about how free speech began with the written word.
     2. Card 2 — Icon: inline SVG engraving-style broken silence line / single horizontal line with a gap (minimal, abstract). Title (exact): "It's Still the First Target". Body: short 1–2 sentence copy about how speech is always the first right suppressed.
     3. Card 3 — Icon: inline SVG engraving-style forward pathway / single converging lines to a point (minimal). Title (exact): "Your Voice Shapes What Comes Next". Body: short 1–2 sentence copy about the power of individual voice in shaping the future.
    - Cards: white background, black text, thin 1px black border or generous spacing — no color fills, no shadows
    - Icons: small, centered above title, stroke-only SVG, ~48px display size
    - Typography: elegant serif for card titles, clean sans-serif for body copy
    - Subtle hover: card lifts slightly on hover via CSS transform only (no JS)
    - Schema settings: section_heading (text), and for each card: title, body, icon_label (for accessibility)
    - No masonry, no heavy JS, no third-party libraries. Fast mobile load. Stack cards vertically on mobile.
    - Output ONLY this single section Liquid code with schema block.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-speech-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 80px 20px;
    background-color: #ffffff;
  }

  .ai-speech-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-speech-heading-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 36px;
    font-weight: 400;
    text-align: center;
    margin: 0 0 80px 0;
    color: #000000;
    letter-spacing: 0.5px;
  }

  .ai-speech-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .ai-speech-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border: 1px solid #000000;
    padding: 60px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .ai-speech-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
  }

  .ai-speech-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    margin-bottom: 32px;
    stroke: #000000;
    fill: none;
  }

  .ai-speech-card-title-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 20px;
    font-weight: 400;
    margin: 0 0 20px 0;
    color: #000000;
    letter-spacing: 0.3px;
  }

  .ai-speech-card-body-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    color: #333333;
  }

  @media screen and (max-width: 990px) {
    .ai-speech-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-speech-heading-{{ ai_gen_id }} {
      font-size: 28px;
      margin-bottom: 50px;
    }

    .ai-speech-section-{{ ai_gen_id }} {
      padding: 60px 20px;
    }

    .ai-speech-card-{{ ai_gen_id }} {
      padding: 50px 30px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-speech-heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 40px;
    }

    .ai-speech-section-{{ ai_gen_id }} {
      padding: 50px 16px;
    }

    .ai-speech-card-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-speech-card-title-{{ ai_gen_id }} {
      font-size: 18px;
    }

    .ai-speech-card-body-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-speech-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-speech-container-{{ ai_gen_id }}">
    <h2 class="ai-speech-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    
    <div class="ai-speech-grid-{{ ai_gen_id }}">
      <div class="ai-speech-card-{{ ai_gen_id }}">
        <svg class="ai-speech-icon-{{ ai_gen_id }}" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-label="{{ block.settings.card_1_icon_label }}">
          <rect x="12" y="8" width="24" height="32" stroke-width="1.5" rx="1"/>
          <line x1="16" y1="14" x2="32" y2="14" stroke-width="1.5"/>
          <line x1="16" y1="18" x2="32" y2="18" stroke-width="1.5"/>
          <line x1="16" y1="22" x2="32" y2="22" stroke-width="1.5"/>
          <line x1="16" y1="26" x2="28" y2="26" stroke-width="1.5"/>
          <line x1="16" y1="30" x2="30" y2="30" stroke-width="1.5"/>
        </svg>
        <h3 class="ai-speech-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        <p class="ai-speech-card-body-{{ ai_gen_id }}">{{ block.settings.card_1_body }}</p>
      </div>

      <div class="ai-speech-card-{{ ai_gen_id }}">
        <svg class="ai-speech-icon-{{ ai_gen_id }}" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-label="{{ block.settings.card_2_icon_label }}">
          <line x1="8" y1="24" x2="18" y2="24" stroke-width="1.5"/>
          <line x1="30" y1="24" x2="40" y2="24" stroke-width="1.5"/>
          <circle cx="24" cy="24" r="3" stroke-width="1.5"/>
        </svg>
        <h3 class="ai-speech-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        <p class="ai-speech-card-body-{{ ai_gen_id }}">{{ block.settings.card_2_body }}</p>
      </div>

      <div class="ai-speech-card-{{ ai_gen_id }}">
        <svg class="ai-speech-icon-{{ ai_gen_id }}" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-label="{{ block.settings.card_3_icon_label }}">
          <line x1="8" y1="40" x2="24" y2="8" stroke-width="1.5"/>
          <line x1="40" y1="40" x2="24" y2="8" stroke-width="1.5"/>
          <circle cx="24" cy="8" r="2" stroke-width="1.5"/>
        </svg>
        <h3 class="ai-speech-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        <p class="ai-speech-card-body-{{ ai_gen_id }}">{{ block.settings.card_3_body }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Why speech is important",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Why Speech Is the Most Important Right"
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "It Started With a Pamphlet"
    },
    {
      "type": "textarea",
      "id": "card_1_body",
      "label": "Body",
      "default": "The written word gave voice to ideas that changed nations. From Common Sense to the Federalist Papers, free expression began with ink and courage."
    },
    {
      "type": "text",
      "id": "card_1_icon_label",
      "label": "Icon accessibility label",
      "default": "Open pamphlet icon"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "It's Still the First Target"
    },
    {
      "type": "textarea",
      "id": "card_2_body",
      "label": "Body",
      "default": "Throughout history, those who seek control silence voices first. When speech falls, all other freedoms follow."
    },
    {
      "type": "text",
      "id": "card_2_icon_label",
      "label": "Icon accessibility label",
      "default": "Broken silence icon"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Your Voice Shapes What Comes Next"
    },
    {
      "type": "textarea",
      "id": "card_3_body",
      "label": "Body",
      "default": "Every generation inherits the duty to speak truth and defend discourse. Your voice today determines the freedoms of tomorrow."
    },
    {
      "type": "text",
      "id": "card_3_icon_label",
      "label": "Icon accessibility label",
      "default": "Forward pathway icon"
    }
  ],
  "presets": [
    {
      "name": "Why speech is important"
    }
  ]
}
{% endschema %}
