{% doc %}
  @prompt
    Regenerate ONLY the "Why Speech Is the Most Important Right" section for Libertas Loqui as clean Shopify Liquid + schema. Brand: calm intellectual courage, strictly non-partisan, monochrome black/white only, extreme negative space.
    
    REQUIREMENTS:
    
    1. SECTION HEADING (exact): "Why Speech Is the Most Important Right"
       - Elegant serif, centered, generous margin below
    
    2. THREE VISUAL CARDS in a CSS grid row (3-col desktop, 1-col mobile, no JS, no masonry):
    
       CARD 1:
       - Icon: inline SVG — open pamphlet/book. Two rectangular pages open flat, center spine line, 2-3 horizontal text lines per page suggesting printed text. Stroke-only, no fill, stroke-width 1.5, black, viewBox="0 0 48 48", width: 48px.
       - Title (exact): "It Started With a Pamphlet"
       - Body: "Every expansion of liberty began with someone willing to write it down. The printed word made ideas permanent, portable, and impossible to unspeak."
    
       CARD 2:
       - Icon: inline SVG — single steady upright flame. One clean teardrop flame shape, stroke-only, no fill, stroke-width 1.5, black, viewBox="0 0 48 48", width: 48px.
       - Title (exact): "It's Still the First Target"
       - Body: "When authority overreaches, speech is always the first right restricted. Protecting it is not a political position — it is a historical observation."
    
       CARD 3:
       - Icon: inline SVG — open pathway. Two lines converging from wide left to a single vanishing point on the right, suggesting a road or horizon. Stroke-only, no fill, stroke-width 1.5, black, viewBox="0 0 48 48", width: 48px.
       - Title (exact): "Your Voice Shapes What Comes Next"
       - Body: "Free expression is not just a right to be defended. It is the mechanism by which a society corrects itself, generation by generation."
    
    3. CARD STYLING:
       - White background, black text
       - Icon centered above title
       - Thin 1px black top border only — no full border, no shadow, no color fill
       - Generous internal padding
       - Hover: CSS transform translateY(-4px), transition 0.2s ease — no JS
    
    4. SCROLL FADE-IN:
       - Cards fade in on scroll via IntersectionObserver + CSS @keyframes opacity 0→1, translateY 20px→0
       - Staggered delay: card 1 = 0ms, card 2 = 150ms, card 3 = 300ms
       - No JS libraries
    
    5. TYPOGRAPHY:
       - Card titles: elegant serif
       - Body copy: clean sans-serif, ~0.95rem, line-height 1.7
    
    6. SCHEMA: section_heading (text), and for each card: title (text), body (textarea)
    
    7. TECHNICAL: No masonry, no third-party JS, fast mobile load, clean valid Liquid syntax with proper {% schema %} block.
    
    Output ONLY this single section Liquid code. No other sections.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-speech-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 120px 20px;
    background-color: #ffffff;
  }

  .ai-speech-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-speech-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: 2.5rem;
    text-align: center;
    color: #000000;
    margin: 0 0 80px 0;
    letter-spacing: -0.02em;
  }

  .ai-speech-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }

  .ai-speech-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    padding: 40px 30px;
    border-top: 1px solid #000000;
    transition: transform 0.2s ease;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-speech-card-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    animation: ai-fade-in-{{ ai_gen_id }} 0.6s ease forwards;
  }

  .ai-speech-card-{{ ai_gen_id }}:nth-child(1).ai-visible-{{ ai_gen_id }} {
    animation-delay: 0ms;
  }

  .ai-speech-card-{{ ai_gen_id }}:nth-child(2).ai-visible-{{ ai_gen_id }} {
    animation-delay: 150ms;
  }

  .ai-speech-card-{{ ai_gen_id }}:nth-child(3).ai-visible-{{ ai_gen_id }} {
    animation-delay: 300ms;
  }

  .ai-speech-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  @keyframes ai-fade-in-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-speech-icon-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }

  .ai-speech-icon-{{ ai_gen_id }} svg {
    width: 48px;
    height: 48px;
  }

  .ai-speech-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: 1.25rem;
    text-align: center;
    color: #000000;
    margin: 0 0 16px 0;
    letter-spacing: -0.01em;
  }

  .ai-speech-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: 0.95rem;
    line-height: 1.7;
    text-align: center;
    color: #000000;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-speech-section-{{ ai_gen_id }} {
      padding: 80px 20px;
    }

    .ai-speech-heading-{{ ai_gen_id }} {
      font-size: 2rem;
      margin-bottom: 60px;
    }

    .ai-speech-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 50px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-speech-section-{{ ai_gen_id }} {
      padding: 60px 16px;
    }

    .ai-speech-heading-{{ ai_gen_id }} {
      font-size: 1.75rem;
      margin-bottom: 50px;
    }

    .ai-speech-card-{{ ai_gen_id }} {
      padding: 30px 20px;
    }
  }
{% endstyle %}

<ai-speech-section-{{ ai_gen_id }} class="ai-speech-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-speech-container-{{ ai_gen_id }}">
    <h2 class="ai-speech-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>

    <div class="ai-speech-grid-{{ ai_gen_id }}">
      <div class="ai-speech-card-{{ ai_gen_id }}" data-card="1">
        <div class="ai-speech-icon-{{ ai_gen_id }}">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 12 L24 12 L24 36 L8 36 Z" stroke="#000000" stroke-width="1.5" fill="none"/>
            <path d="M24 12 L40 12 L40 36 L24 36" stroke="#000000" stroke-width="1.5" fill="none"/>
            <line x1="12" y1="18" x2="20" y2="18" stroke="#000000" stroke-width="1.5"/>
            <line x1="12" y1="22" x2="20" y2="22" stroke="#000000" stroke-width="1.5"/>
            <line x1="12" y1="26" x2="20" y2="26" stroke="#000000" stroke-width="1.5"/>
            <line x1="28" y1="18" x2="36" y2="18" stroke="#000000" stroke-width="1.5"/>
            <line x1="28" y1="22" x2="36" y2="22" stroke="#000000" stroke-width="1.5"/>
            <line x1="28" y1="26" x2="36" y2="26" stroke="#000000" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="ai-speech-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        <p class="ai-speech-body-{{ ai_gen_id }}">{{ block.settings.card_1_body }}</p>
      </div>

      <div class="ai-speech-card-{{ ai_gen_id }}" data-card="2">
        <div class="ai-speech-icon-{{ ai_gen_id }}">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 10 C24 10, 18 16, 18 24 C18 32, 24 38, 24 38 C24 38, 30 32, 30 24 C30 16, 24 10, 24 10 Z" stroke="#000000" stroke-width="1.5" fill="none"/>
          </svg>
        </div>
        <h3 class="ai-speech-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        <p class="ai-speech-body-{{ ai_gen_id }}">{{ block.settings.card_2_body }}</p>
      </div>

      <div class="ai-speech-card-{{ ai_gen_id }}" data-card="3">
        <div class="ai-speech-icon-{{ ai_gen_id }}">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="8" y1="38" x2="40" y2="24" stroke="#000000" stroke-width="1.5"/>
            <line x1="8" y1="10" x2="40" y2="24" stroke="#000000" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="ai-speech-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        <p class="ai-speech-body-{{ ai_gen_id }}">{{ block.settings.card_3_body }}</p>
      </div>
    </div>
  </div>
</ai-speech-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiSpeechSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-speech-card-{{ ai_gen_id }}');
        this.setupObserver();
      }

      setupObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
            }
          });
        }, options);

        this.cards.forEach(card => {
          observer.observe(card);
        });
      }
    }

    customElements.define('ai-speech-section-{{ ai_gen_id }}', AiSpeechSection{{ ai_gen_id }});
  })();
</script>

