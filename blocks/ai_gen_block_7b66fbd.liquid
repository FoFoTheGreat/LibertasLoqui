{% doc %}
  @prompt
    Create a testimonial carousel section for Libertas Loqui, a First Amendment apparel brand. Brand voice: calm confidence, sharp intellect, bold but not loud.
    
    SPECS:
    - Section heading: 'What People Are Saying' in bold sans-serif (Inter or DM Sans)
    - 4 testimonial cards in a smooth auto-scrolling carousel with manual navigation dots and prev/next arrows
    - Each card has: 5 gold stars, a quote, a placeholder customer name, and a placeholder city/state
    - Testimonial 1: 'Finally a brand that stands for something timeless. I wear this every day as a reminder of what actually matters.' — J. Mitchell, Austin TX
    - Testimonial 2: 'The quality is exceptional and the message is one I’m proud to carry. This isn’t just apparel — it’s a statement.' — R. Caldwell, Nashville TN
    - Testimonial 3: 'In a world full of noise, Libertas Loqui cuts through with clarity. Beautifully made, powerfully principled.' — A. Torres, Denver CO
    - Testimonial 4: 'I’ve never felt more aligned with a brand. The craftsmanship matches the conviction.' — S. Harmon, Philadelphia PA
    - Smooth auto-scroll every 5 seconds, pause on hover, manual dot navigation
    - High whitespace, minimal palette (black, white, off-white, gold stars)
    - Mobile-first responsive, no heavy libraries
    - Output as a ready-to-insert Shopify Liquid theme section, carousel is glitching out
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonial-carousel-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-testimonial-carousel-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    letter-spacing: -0.02em;
  }

  .ai-testimonial-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .ai-testimonial-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-testimonial-carousel-slide-{{ ai_gen_id }} {
    min-width: 100%;
    padding: 0 10px;
    box-sizing: border-box;
    flex-shrink: 0;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 24px;
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};
    font-weight: {{ block.settings.quote_font.weight }};
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    margin: 0 0 24px;
    font-style: italic;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    font-family: {{ block.settings.author_font.family }}, {{ block.settings.author_font.fallback_families }};
    font-weight: {{ block.settings.author_font.weight }};
    font-size: {{ block.settings.author_size }}px;
    color: {{ block.settings.author_color }};
    margin: 0;
  }

  .ai-testimonial-location-{{ ai_gen_id }} {
    font-family: {{ block.settings.author_font.family }}, {{ block.settings.author_font.fallback_families }};
    font-size: {{ block.settings.location_size }}px;
    color: {{ block.settings.location_color }};
    margin: 4px 0 0;
  }

  .ai-testimonial-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
  }

  .ai-testimonial-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
  }

  .ai-testimonial-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.4;
  }

  .ai-testimonial-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-testimonial-arrow-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.arrow_color }};
    transition: opacity 0.3s ease;
  }

  .ai-testimonial-arrow-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-testimonial-arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-carousel-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
    }

    .ai-testimonial-quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_size | times: 0.85 }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<testimonial-carousel-{{ ai_gen_id }}
  class="ai-testimonial-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-interval="{{ block.settings.autoplay_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-testimonial-carousel-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-testimonial-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-testimonial-carousel-track-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign quote_key = 'testimonial_' | append: i | append: '_quote'
            assign author_key = 'testimonial_' | append: i | append: '_author'
            assign location_key = 'testimonial_' | append: i | append: '_location'

            assign quote = block.settings[quote_key]
            assign author = block.settings[author_key]
            assign location = block.settings[location_key]
          %}

          <div class="ai-testimonial-carousel-slide-{{ ai_gen_id }}">
            <div class="ai-testimonial-card-{{ ai_gen_id }}">
              <div class="ai-testimonial-stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  <svg class="ai-testimonial-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>

              {% if quote != blank %}
                <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ quote }}</p>
              {% endif %}

              {% if author != blank %}
                <p class="ai-testimonial-author-{{ ai_gen_id }}">{{ author }}</p>
              {% endif %}

              {% if location != blank %}
                <p class="ai-testimonial-location-{{ ai_gen_id }}">{{ location }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-testimonial-nav-{{ ai_gen_id }}">
      <button class="ai-testimonial-arrow-{{ ai_gen_id }} ai-testimonial-prev-{{ ai_gen_id }}" aria-label="Previous testimonial">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-testimonial-dots-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          <button
            class="ai-testimonial-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
            data-index="{{ i | minus: 1 }}"
            aria-label="Go to testimonial {{ i }}"
          ></button>
        {% endfor %}
      </div>

      <button class="ai-testimonial-arrow-{{ ai_gen_id }} ai-testimonial-next-{{ ai_gen_id }}" aria-label="Next testimonial">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</testimonial-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 4;
        this.autoplayInterval = null;
        this.isPaused = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-testimonial-carousel-track-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-testimonial-dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-testimonial-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-testimonial-next-{{ ai_gen_id }}');
        this.wrapper = this.querySelector('.ai-testimonial-carousel-wrapper-{{ ai_gen_id }}');

        this.autoplay = this.dataset.autoplay === 'true';
        this.interval = parseInt(this.dataset.interval) * 1000;

        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.goToPrevious());
        this.nextButton.addEventListener('click', () => this.goToNext());

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
          });
        });

        this.wrapper.addEventListener('mouseenter', () => {
          this.isPaused = true;
          this.stopAutoplay();
        });

        this.wrapper.addEventListener('mouseleave', () => {
          this.isPaused = false;
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
        this.resetAutoplay();
      }

      goToNext() {
        this.currentIndex = (this.currentIndex + 1) % this.totalSlides;
        this.updateCarousel();
        this.resetAutoplay();
      }

      goToPrevious() {
        this.currentIndex = (this.currentIndex - 1 + this.totalSlides) % this.totalSlides;
        this.updateCarousel();
        this.resetAutoplay();
      }

      updateCarousel() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        if (!this.autoplay || this.isPaused) return;

        this.autoplayInterval = setInterval(() => {
          this.goToNext();
        }, this.interval);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        this.stopAutoplay();
        if (this.autoplay && !this.isPaused) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('testimonial-carousel-{{ ai_gen_id }}', TestimonialCarousel{{ ai_gen_id }});
  })();
</script>

