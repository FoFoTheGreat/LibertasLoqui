{% doc %}
  @prompt
    Generate ONLY the Hero section for Libertas Loqui as a clean Shopify Liquid section file with schema. Brand: calm intellectual courage, strictly non-partisan, monochrome black/white/gray only.
    
    REQUIREMENTS:
    - Full-width section, extreme negative space
    - Background: ultra-minimal engraving line-art inline SVG — single upright classical Liberty Torch with steady flame illuminating an open scroll. Fine stroke lines only, no fill, short explicit path definitions, lightweight SVG. Positioned as large faint watermark behind text. NO chains, NO megaphones, NO breaking elements, NO protest imagery, NO flags, NO eagles.
    - Headline (exact): "Your Voice Is the First Freedom."
    - Subheadline (exact): "Wear the principle that protects every other right."
    - Primary CTA: "Shop the Collection" — solid black button, white text
    - Secondary CTA: "Read the Covenant" — underlined text link, black
    - CTA animation: CSS @keyframes fade-in triggered by IntersectionObserver — no JS libraries, no third-party dependencies
    - Typography: elegant serif for headline, clean sans-serif for subheadline and CTAs
    - Layout: centered text over SVG watermark, generous vertical padding
    - Schema settings: heading (text), subheading (text), primary_cta_label (text), primary_cta_link (url), secondary_cta_label (text), secondary_cta_link (url)
    - Include placeholder: div id="hero-ugc-carousel" with HTML comment "Judge.me or Klaviyo UGC embed point"
    - No masonry, no heavy JS, no third-party libraries. Fast mobile load.
    - Output ONLY this single section Liquid code with schema block., background is blank and there are no links to shop or priniciple
{% enddoc %}
```liquid
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ll-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    overflow: hidden;
    padding: 120px 40px;
  }

  .ll-hero-svg-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    max-width: 800px;
    height: auto;
    opacity: 0.08;
    pointer-events: none;
    z-index: 1;
  }

  .ll-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .ll-hero-headline-{{ ai_gen_id }} {
    font-family: 'Merriweather', Georgia, serif;
    font-size: 64px;
    font-weight: 400;
    line-height: 1.2;
    color: #000000;
    margin: 0 0 32px 0;
    letter-spacing: -0.02em;
  }

  .ll-hero-subheadline-{{ ai_gen_id }} {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.6;
    color: #2c2c2c;
    margin: 0 0 56px 0;
    letter-spacing: 0.01em;
  }

  .ll-hero-cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    opacity: 0;
  }

  .ll-hero-cta-wrapper-{{ ai_gen_id }}.fade-in {
    animation: ll-hero-fade-in-{{ ai_gen_id }} 1s ease-out forwards;
    animation-delay: 0.3s;
  }

  .ll-hero-primary-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 18px 48px;
    background-color: #000000;
    color: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    border: 2px solid #000000;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
  }

  .ll-hero-primary-cta-{{ ai_gen_id }}:hover {
    background-color: #ffffff;
    color: #000000;
  }

  .ll-hero-secondary-cta-{{ ai_gen_id }} {
    display: inline-block;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #000000;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.3s ease;
    letter-spacing: 0.02em;
  }

  .ll-hero-secondary-cta-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ll-hero-ugc-{{ ai_gen_id }} {
    margin-top: 80px;
    min-height: 60px;
  }

  @keyframes ll-hero-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 989px) {
    .ll-hero-{{ ai_gen_id }} {
      min-height: 80vh;
      padding: 80px 32px;
    }

    .ll-hero-headline-{{ ai_gen_id }} {
      font-size: 48px;
      margin-bottom: 24px;
    }

    .ll-hero-subheadline-{{ ai_gen_id }} {
      font-size: 18px;
      margin-bottom: 40px;
    }

    .ll-hero-svg-{{ ai_gen_id }} {
      width: 80%;
    }

    .ll-hero-cta-wrapper-{{ ai_gen_id }} {
      gap: 24px;
    }

    .ll-hero-ugc-{{ ai_gen_id }} {
      margin-top: 60px;
    }
  }

  @media screen and (max-width: 749px) {
    .ll-hero-{{ ai_gen_id }} {
      min-height: 70vh;
      padding: 60px 24px;
    }

    .ll-hero-headline-{{ ai_gen_id }} {
      font-size: 36px;
      margin-bottom: 20px;
    }

    .ll-hero-subheadline-{{ ai_gen_id }} {
      font-size: 16px;
      margin-bottom: 32px;
    }

    .ll-hero-svg-{{ ai_gen_id }} {
      width: 100%;
    }

    .ll-hero-cta-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 20px;
    }

    .ll-hero-primary-cta-{{ ai_gen_id }} {
      padding: 16px 40px;
      font-size: 15px;
    }

    .ll-hero-secondary-cta-{{ ai_gen_id }} {
      font-size: 15px;
    }

    .ll-hero-ugc-{{ ai_gen_id }} {
      margin-top: 48px;
    }
  }
{% endstyle %}

