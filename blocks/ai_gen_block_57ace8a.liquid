{% doc %}
  @prompt
    Generate ONLY the "Launch Collection" section for Libertas Loqui as a clean Shopify Liquid section file with schema. Brand: calm intellectual courage, strictly non-partisan, monochrome black/white/gray only, extreme negative space.
    
    REQUIREMENTS:
    - Section heading (exact): "The 1A Defender Collection"
    - Display 6 products from a collection using Shopify Liquid collection object (configurable via schema collection picker)
    - Clean CSS grid layout: 3 columns on desktop, 2 columns on tablet, 1 column on mobile. NO masonry, NO JS grid libraries.
    - Each product card contains:
      - Product image (native Shopify image_url, lazy loaded)
      - Product title — use ONLY clean titles. Strip or ignore any title containing "Freedom Breaks Chains" or "Megaphone" — display as "Silence Is Not Liberty T-Shirt" and "Voice Is Power T-Shirt" respectively if those products appear
      - Price — clean, no decorative formatting
      - "Shop Now" text link below price, underlined, black
    - Card style: white background, black text, no shadows, no color fills, thin 1px black bottom border only on hover (CSS only)
    - Simple filter row above the grid: 2–3 text filter buttons (e.g., "All", "Tees", "Accessories") — CSS class toggle via minimal vanilla JS only, no libraries. Buttons: plain text, black, underlined when active.
    - NO "Build Your Principle" selector (remove from scope — keep it simple and fast)
    - Schema settings: section_heading (text), collection (collection picker), filter_label_1, filter_label_2, filter_label_3 (text)
    - Include placeholder div: id="collection-ugc-carousel" with HTML comment "Judge.me or Klaviyo UGC photo carousel embed point"
    - Fast mobile load, lightweight, no third-party JS
    - Output ONLY this single section Liquid code with schema block., none of the shirts are appearing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-launch-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.page_width }}px;
    margin: 0 auto;
    padding: 80px 20px;
    background-color: #ffffff;
  }

  .ai-collection-launch__heading-{{ ai_gen_id }} {
    font-family: 'Merriweather', serif;
    font-size: 48px;
    font-weight: 400;
    text-align: center;
    color: #000000;
    margin: 0 0 80px;
    letter-spacing: -0.5px;
  }

  .ai-collection-launch__filters-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 60px;
  }

  .ai-collection-launch__filter-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .ai-collection-launch__filter-btn-{{ ai_gen_id }}.active {
    border-bottom-color: #000000;
  }

  .ai-collection-launch__filter-btn-{{ ai_gen_id }}:hover {
    border-bottom-color: #000000;
  }

  .ai-collection-launch__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-bottom: 80px;
  }

  .ai-collection-launch__card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }

  .ai-collection-launch__card-{{ ai_gen_id }}:hover {
    border-bottom-color: #000000;
  }

  .ai-collection-launch__card-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 20px;
    overflow: hidden;
  }

  .ai-collection-launch__card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collection-launch__card-title-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #000000;
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .ai-collection-launch__card-price-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    margin: 0 0 12px;
  }

  .ai-collection-launch__card-link-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    text-decoration: underline;
    display: inline-block;
  }

  .ai-collection-launch__ugc-{{ ai_gen_id }} {
    margin-top: 80px;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-launch__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .ai-collection-launch__heading-{{ ai_gen_id }} {
      font-size: 36px;
      margin-bottom: 60px;
    }

    .ai-collection-launch__filters-{{ ai_gen_id }} {
      gap: 30px;
      margin-bottom: 40px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-launch-{{ ai_gen_id }} {
      padding: 60px 16px;
    }

    .ai-collection-launch__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-collection-launch__heading-{{ ai_gen_id }} {
      font-size: 28px;
      margin-bottom: 40px;
    }

    .ai-collection-launch__filters-{{ ai_gen_id }} {
      gap: 24px;
      margin-bottom: 32px;
    }

    .ai-collection-launch__ugc-{{ ai_gen_id }} {
      margin-top: 60px;
    }
  }
{% endstyle %}

<collection-launch-{{ ai_gen_id }} class="ai-collection-launch-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_heading != blank %}
    <h2 class="ai-collection-launch__heading-{{ ai_gen_id }}">
      {{ block.settings.section_heading }}
    </h2>
  {% endif %}

  {% if block.settings.filter_label_1 != blank or block.settings.filter_label_2 != blank or block.settings.filter_label_3 != blank %}
    <div class="ai-collection-launch__filters-{{ ai_gen_id }}">
      {% if block.settings.filter_label_1 != blank %}
        <button
          class="ai-collection-launch__filter-btn-{{ ai_gen_id }} active"
          data-filter="all"
        >
          {{ block.settings.filter_label_1 }}
        </button>
      {% endif %}
      {% if block.settings.filter_label_2 != blank %}
        <button
          class="ai-collection-launch__filter-btn-{{ ai_gen_id }}"
          data-filter="filter2"
        >
          {{ block.settings.filter_label_2 }}
        </button>
      {% endif %}
      {% if block.settings.filter_label_3 != blank %}
        <button
          class="ai-collection-launch__filter-btn-{{ ai_gen_id }}"
          data-filter="filter3"
        >
          {{ block.settings.filter_label_3 }}
        </button>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-collection-launch__grid-{{ ai_gen_id }}">
    {% if block.settings.collection != blank %}
      {% assign products_to_show = block.settings.collection.products | slice: 0, 6 %}
      {% for product in products_to_show %}
        {% assign clean_title = product.title %}
        {% if product.title contains 'Freedom Breaks Chains' %}
          {% assign clean_title = 'Silence Is Not Liberty T-Shirt' %}
        {% elsif product.title contains 'Megaphone' %}
          {% assign clean_title = 'Voice Is Power T-Shirt' %}
        {% endif %}

        <div class="ai-collection-launch__card-{{ ai_gen_id }}">
          <div class="ai-collection-launch__card-image-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ product.featured_image.alt | escape }}"
                width="800"
                height="800"
                loading="lazy"
              >
            {% else %}
              <div style="width: 100%; height: 100%; background-color: #f4f4f4;"></div>
            {% endif %}
          </div>
          <h3 class="ai-collection-launch__card-title-{{ ai_gen_id }}">
            {{ clean_title }}
          </h3>
          <div class="ai-collection-launch__card-price-{{ ai_gen_id }}">
            {{ product.price | money }}
          </div>
          <a
            href="{{ product.url }}"
            class="ai-collection-launch__card-link-{{ ai_gen_id }}"
          >
            Shop Now
          </a>
        </div>
      {% endfor %}
    {% else %}
      {% for i in (1..6) %}
        <div class="ai-collection-launch__card-{{ ai_gen_id }}">
          <div class="ai-collection-launch__card-image-{{ ai_gen_id }}">
            <div style="width: 100%; height: 100%; background-color: #f4f4f4;"></div>
          </div>
          <h3 class="ai-collection-launch__card-title-{{ ai_gen_id }}">
            Product Title
          </h3>
          <div class="ai-collection-launch__card-price-{{ ai_gen_id }}">
            $0.00
          </div>
          <a
            href="#"
            class="ai-collection-launch__card-link-{{ ai_gen_id }}"
          >
            Shop Now
          </a>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <div
    id="collection-ugc-carousel"
    class="ai-collection-launch__ugc-{{ ai_gen_id }}"
  >
  </div>
</collection-launch-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionLaunch{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-collection-launch__filter-btn-{{ ai_gen_id }}');
        this.setupFilters();
      }

      setupFilters() {
        this.filterButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.filterButtons.forEach((btn) => btn.classList.remove('active'));
            button.classList.add('active');
          });
        });
      }
    }

    customElements.define('collection-launch-{{ ai_gen_id }}', CollectionLaunch{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "1A Defender Collection",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "The 1A Defender Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "page_width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "text",
      "id": "filter_label_1",
      "label": "Filter 1 label",
      "default": "All"
    },
    {
      "type": "text",
      "id": "filter_label_2",
      "label": "Filter 2 label",
      "default": "Tees"
    },
    {
      "type": "text",
      "id": "filter_label_3",
      "label": "Filter 3 label",
      "default": "Accessories"
    }
  ],
  "presets": [
    {
      "name": "1A Defender Collection"
    }
  ]
}
{% endschema %}
