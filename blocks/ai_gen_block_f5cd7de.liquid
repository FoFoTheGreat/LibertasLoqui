{% doc %}
  @prompt
    Regenerate the complete "Libertas Loqui Covenant" section for Libertas Loqui as a single clean Shopify Liquid section file with schema. Brand: calm intellectual courage, strictly non-partisan, monochrome black/white/gray only, extreme negative space.
    
    REQUIREMENTS:
    
    1. QUILL + BOOK ICON (hardcoded inline SVG at top of section, above heading):
    - A quill pen resting diagonally on an open book
    - Fine black strokes only (#000000), stroke-width 1.5, stroke-linecap round, stroke-linejoin round, NO fill, transparent background
    - viewBox="0 0 120 80", displayed width: 96px, height: auto
    - Centered, margin-bottom: 2rem
    - Quill: long diagonal feather with pointed nib at bottom-left, 3-4 simple barb lines along shaft
    - Book: open rectangle split at center spine, 2 subtle page-curve lines per side
    - Wrap in: div class="covenant-icon" style="text-align:center"
    
    2. SECTION HEADING below icon (exact): "The Libertas Loqui Covenant"
    - Elegant serif, centered, generous margin below
    
    3. COVENANT TEXT BLOCK:
    - Editable via schema richtext field (id: "covenant_text")
    - Serif font, generous line-height 1.8, centered or left-aligned with wide margins
    - Initially truncated to ~4 lines with overflow hidden
    
    4. FAINT BACKGROUND WATERMARK:
    - Inline SVG of Liberty Torch + open scroll, stroke-only, opacity 0.06, position: absolute, centered behind text. Short lightweight paths only. NO chains, NO megaphones.
    
    5. EXPAND/COLLAPSE:
    - "Read the Full Covenant" text link below truncated text
    - Smooth CSS max-height transition to expand full text
    - Label toggles to "Close" when expanded — minimal vanilla JS toggle only, no libraries
    - Schema settings: button_label_open (text), button_label_close (text)
    
    6. TECHNICAL:
    - No color fills, no shadows, no decorative borders
    - Fast mobile load, graceful single-column on small screens
    - Clean valid Liquid syntax — no undefined variables, no missing endfor/endif tags
    - Schema: section_heading (text), covenant_text (richtext), button_label_open (text), button_label_close (text)
    - Output ONLY this complete section Liquid code with schema block. No other sections., increase txt size slightly
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .covenant-section-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    padding: 80px 20px;
    background-color: #ffffff;
    overflow: hidden;
  }

  .covenant-container-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .covenant-icon-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 2rem;
  }

  .covenant-icon-{{ ai_gen_id }} svg {
    width: 96px;
    height: auto;
  }

  .covenant-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-size: 2.75rem;
    font-weight: 400;
    text-align: center;
    color: #000000;
    margin: 0 0 3rem;
    letter-spacing: 0.02em;
  }

  .covenant-text-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    max-height: 8em;
    transition: max-height 0.6s ease;
  }

  .covenant-text-wrapper-{{ ai_gen_id }}.expanded {
    max-height: 200em;
  }

  .covenant-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, serif;
    font-size: 1.25rem;
    line-height: 1.8;
    color: #2c2c2c;
    text-align: left;
    margin: 0 auto 2rem;
    max-width: 700px;
  }

  .covenant-text-{{ ai_gen_id }} p {
    margin-bottom: 1.5em;
  }

  .covenant-toggle-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 2rem;
  }

  .covenant-toggle-link-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    font-size: 1rem;
    color: #000000;
    text-decoration: none;
    border-bottom: 1px solid #000000;
    padding-bottom: 2px;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .covenant-toggle-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .covenant-watermark-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    opacity: 0.06;
    z-index: 1;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .covenant-section-{{ ai_gen_id }} {
      padding: 60px 20px;
    }

    .covenant-heading-{{ ai_gen_id }} {
      font-size: 2.25rem;
      margin-bottom: 2rem;
    }

    .covenant-text-{{ ai_gen_id }} {
      font-size: 1.125rem;
    }

    .covenant-watermark-{{ ai_gen_id }} {
      width: 300px;
      height: 300px;
    }
  }
{% endstyle %}

<covenant-section-{{ ai_gen_id }} class="covenant-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="covenant-watermark-{{ ai_gen_id }}">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#000000" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
      <path d="M100 40 L100 90 M95 85 L100 90 L105 85" />
      <ellipse cx="100" cy="95" rx="8" ry="12" />
      <path d="M92 100 Q92 115 100 120 Q108 115 108 100" />
      <path d="M60 130 L60 170 L140 170 L140 130" />
      <path d="M65 135 Q70 130 75 135 L75 165" />
      <path d="M85 135 Q90 130 95 135 L95 165" />
      <path d="M105 135 Q110 130 115 135 L115 165" />
      <path d="M125 135 Q130 130 135 135 L135 165" />
      <line x1="60" y1="130" x2="140" y2="130" />
    </svg>
  </div>

  <div class="covenant-container-{{ ai_gen_id }}">
    <div class="covenant-icon-{{ ai_gen_id }}">
      <svg viewBox="0 0 120 80" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="20" y="25" width="80" height="50" rx="2" />
        <line x1="60" y1="25" x2="60" y2="75" />
        <path d="M25 30 Q30 28 35 30" />
        <path d="M25 40 Q30 38 35 40" />
        <path d="M65 30 Q70 28 75 30" />
        <path d="M65 40 Q70 38 75 40" />
        <path d="M85 15 L45 65" />
        <path d="M87 17 L86 20" />
        <path d="M83 19 L82 22" />
        <path d="M79 21 L78 24" />
        <path d="M75 23 L74 26" />
        <ellipse cx="44" cy="66" rx="2" ry="3" />
      </svg>
    </div>

    <h2 class="covenant-heading-{{ ai_gen_id }}">
      {% if block.settings.section_heading != blank %}
        {{ block.settings.section_heading }}
      {% else %}
        The Libertas Loqui Covenant
      {% endif %}
    </h2>

    <div class="covenant-text-wrapper-{{ ai_gen_id }}" data-wrapper>
      <div class="covenant-text-{{ ai_gen_id }}">
        {% if block.settings.covenant_text != blank %}
          {{ block.settings.covenant_text }}
        {% else %}
          <p>We believe in the enduring power of free expression—not as a partisan tool, but as a foundational principle that belongs to all. Our covenant is simple: to create apparel that honors the First Amendment with integrity, craftsmanship, and unwavering respect for diverse voices.</p>
          <p>Every piece we produce is made in the United States, reflecting our commitment to quality and transparency. We stand for open dialogue, intellectual courage, and the right of every individual to speak, question, and be heard.</p>
          <p>This is not about left or right. This is about liberty.</p>
        {% endif %}
      </div>
    </div>

    <div class="covenant-toggle-{{ ai_gen_id }}">
      <a class="covenant-toggle-link-{{ ai_gen_id }}" data-toggle>
        <span data-label-open>
          {% if block.settings.button_label_open != blank %}
            {{ block.settings.button_label_open }}
          {% else %}
            Read the Full Covenant
          {% endif %}
        </span>
        <span data-label-close style="display: none;">
          {% if block.settings.button_label_close != blank %}
            {{ block.settings.button_label_close }}
          {% else %}
            Close
          {% endif %}
        </span>
      </a>
    </div>
  </div>
</covenant-section-{{ ai_gen_id }}>

<script>
  (function() {
    class CovenantSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('[data-wrapper]');
        this.toggle = this.querySelector('[data-toggle]');
        this.labelOpen = this.querySelector('[data-label-open]');
        this.labelClose = this.querySelector('[data-label-close]');

        if (this.toggle && this.wrapper) {
          this.toggle.addEventListener('click', this.handleToggle.bind(this));
        }
      }

      handleToggle(event) {
        event.preventDefault();
        const isExpanded = this.wrapper.classList.contains('expanded');

        if (isExpanded) {
          this.wrapper.classList.remove('expanded');
          this.labelOpen.style.display = 'inline';
          this.labelClose.style.display = 'none';
        } else {
          this.wrapper.classList.add('expanded');
          this.labelOpen.style.display = 'none';
          this.labelClose.style.display = 'inline';
        }
      }
    }

    customElements.define('covenant-section-{{ ai_gen_id }}', CovenantSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Libertas Loqui Covenant",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "The Libertas Loqui Covenant"
    },
    {
      "type": "richtext",
      "id": "covenant_text",
      "label": "Covenant text",
      "default": "<p>We believe in the enduring power of free expression—not as a partisan tool, but as a foundational principle that belongs to all. Our covenant is simple: to create apparel that honors the First Amendment with integrity, craftsmanship, and unwavering respect for diverse voices.</p><p>Every piece we produce is made in the United States, reflecting our commitment to quality and transparency. We stand for open dialogue, intellectual courage, and the right of every individual to speak, question, and be heard.</p><p>This is not about left or right. This is about liberty.</p>"
    },
    {
      "type": "text",
      "id": "button_label_open",
      "label": "Expand button label",
      "default": "Read the Full Covenant"
    },
    {
      "type": "text",
      "id": "button_label_close",
      "label": "Collapse button label",
      "default": "Close"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "serif"
    }
  ],
  "presets": [
    {
      "name": "Libertas Loqui Covenant"
    }
  ]
}
{% endschema %}
