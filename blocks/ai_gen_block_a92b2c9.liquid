{% doc %}
  @prompt
    Create a scroll-triggered 3-card section titled 'Why Speech Is the Most Important Right' for Libertas Loqui, a First Amendment apparel brand. Brand voice: calm confidence, sharp intellect, bold but not loud. Non-partisan language throughout.
    
    SPECS:
    - Section heading: 'Why Speech Is the Most Important Right' in bold sans-serif (Inter or DM Sans)
    - Three cards in a horizontal row on desktop, stacked on mobile
    - Each card has a subtle icon, bold card title, and 2-3 sentences of body text
    - Card 1: Title: 'It Started With a Pamphlet' — Body: 'Before the internet, before broadcast media, the pamphlet was the weapon of the free mind. Pamphleteers like Thomas Paine didn’t just document history — they made it. Speech has always been the first tool of those who refuse to be silent.'
    - Card 2: Title: 'It’s Still the First Target' — Body: 'Every authoritarian system, without exception, moves first to control speech. Not guns. Not property. Words. Because those in power know that ideas, once spoken freely, cannot be unheard.'
    - Card 3: Title: 'Your Voice Shapes What Comes Next' — Body: 'Culture, law, and the future are not handed down — they are argued into existence. What you say, share, and stand for today becomes the world your children inherit tomorrow.'
    - Cards animate into view on scroll using Intersection Observer (no heavy libraries)
    - High whitespace, minimal palette (black, white, off-white, one accent)
    - Mobile-first responsive
    - Output as a ready-to-insert Shopify Liquid theme section, increase contrast to add depth to the page to trigger emotion
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-speech-rights-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-speech-rights-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-speech-rights-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .ai-speech-rights-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.cards_margin_top }}px;
  }

  .ai-speech-rights-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.3s ease;
  }

  .ai-speech-rights-card-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-speech-rights-card-{{ ai_gen_id }}:hover {
    box-shadow: {{ block.settings.card_shadow_horizontal | times: 1.5 }}px {{ block.settings.card_shadow_vertical | times: 1.5 }}px {{ block.settings.card_shadow_blur | times: 1.5 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-speech-rights-card-{{ ai_gen_id }}:nth-child(1) {
    transition-delay: 0.1s;
  }

  .ai-speech-rights-card-{{ ai_gen_id }}:nth-child(2) {
    transition-delay: 0.2s;
  }

  .ai-speech-rights-card-{{ ai_gen_id }}:nth-child(3) {
    transition-delay: 0.3s;
  }

  .ai-speech-rights-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_margin_bottom }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-speech-rights-card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_title_font.family }}, {{ block.settings.card_title_font.fallback_families }};
    font-weight: {{ block.settings.card_title_font.weight }};
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_margin_bottom }}px;
    line-height: 1.3;
  }

  .ai-speech-rights-card-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_body_font.family }}, {{ block.settings.card_body_font.fallback_families }};
    font-weight: {{ block.settings.card_body_font.weight }};
    font-size: {{ block.settings.card_body_size }}px;
    color: {{ block.settings.card_body_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-speech-rights-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top }}px 40px {{ block.settings.section_padding_bottom }}px;
    }

    .ai-speech-rights-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 1.2 }}px;
    }

    .ai-speech-rights-cards-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ block.settings.card_gap | times: 1.5 }}px;
    }

    .ai-speech-rights-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 1.1 }}px;
    }

    .ai-speech-rights-card-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_body_size | times: 1.05 }}px;
    }
  }
{% endstyle %}

<speech-rights-{{ ai_gen_id }} class="ai-speech-rights-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-speech-rights-container-{{ ai_gen_id }}">
    <h2 class="ai-speech-rights-heading-{{ ai_gen_id }}">
      {{ block.settings.section_heading }}
    </h2>

    <div class="ai-speech-rights-cards-{{ ai_gen_id }}">
      <div class="ai-speech-rights-card-{{ ai_gen_id }}" data-card="1">
        <svg class="ai-speech-rights-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
        <h3 class="ai-speech-rights-card-title-{{ ai_gen_id }}">
          {{ block.settings.card_1_title }}
        </h3>
        <p class="ai-speech-rights-card-body-{{ ai_gen_id }}">
          {{ block.settings.card_1_body }}
        </p>
      </div>

      <div class="ai-speech-rights-card-{{ ai_gen_id }}" data-card="2">
        <svg class="ai-speech-rights-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <h3 class="ai-speech-rights-card-title-{{ ai_gen_id }}">
          {{ block.settings.card_2_title }}
        </h3>
        <p class="ai-speech-rights-card-body-{{ ai_gen_id }}">
          {{ block.settings.card_2_body }}
        </p>
      </div>

      <div class="ai-speech-rights-card-{{ ai_gen_id }}" data-card="3">
        <svg class="ai-speech-rights-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <h3 class="ai-speech-rights-card-title-{{ ai_gen_id }}">
          {{ block.settings.card_3_title }}
        </h3>
        <p class="ai-speech-rights-card-body-{{ ai_gen_id }}">
          {{ block.settings.card_3_body }}
        </p>
      </div>
    </div>
  </div>
</speech-rights-{{ ai_gen_id }}>

<script>
  (function() {
    class SpeechRights{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.cards = this.querySelectorAll('.ai-speech-rights-card-{{ ai_gen_id }}');
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px 0px -100px 0px',
          threshold: 0.2
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
            }
          });
        }, options);

        this.cards.forEach((card) => {
          this.observer.observe(card);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('speech-rights-{{ ai_gen_id }}', SpeechRights{{ ai_gen_id }});
  })();
</script>

