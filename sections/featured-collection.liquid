{% comment %} Fixed 1A Defender Collection – No Duplicates | Libertas Loqui {% endcomment %}
<div class="featured-collection page-width">
  <h1 class="title">{{ section.settings.title | default: "The 1A Defender Collection" }}</h1>
  <p class="subtitle">Minimal designs. Premium American craftsmanship. A daily reminder that open dialogue still matters.</p>

  <div class="grid grid--2-col-tablet grid--4-col-desktop">
    {% for product in section.settings.collection.products limit: 6 %}
      <div class="product-card">
        <a href="{{ product.url }}" class="product-card__link">
          <div class="product-card__media">
            {% if product.featured_media %}
              {{ product.featured_media | image_url: width: 400 | image_tag: 
                loading: 'lazy',
                widths: '200, 400, 600',
                class: 'product-card__image',
                alt: product.featured_media.alt | escape
              }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">{{ product.title | escape }}</h3>
            <span class="product-card__price">
              {{ product.price | money }}
              {% if product.compare_at_price > product.price %}
                <s class="product-card__compare-price">{{ product.compare_at_price | money }}</s>
              {% endif %}
            </span>
          </div>
        </a>
      </div>
    {% endfor %}
  </div>

  <div class="center">
    <a href="/collections/1a-defender-collection" class="button button--primary">Explore the Collection</a>
  </div>
</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "text", "id": "title", "label": "Heading", "default": "The 1A Defender Collection"}
  ],
  "presets": [{"name": "Featured Collection"}]
}
{% endschema %}