{% comment %} Complete the Uniform – tied to principle_tie_in metafield {% endcomment %}

{%- if product.metafields.custom.principle_tie_in != blank -%}
<section class="complete-uniform">
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  {%- if section.settings.subheading != blank -%}
    <p class="section-subheading">{{ section.settings.subheading }}</p>
  {%- endif -%}
  <div class="grid grid--2-col-tablet">
    {%- for tied_product in product.metafields.custom.principle_tie_in.value -%}
      {%- render 'card-product', product: tied_product, show_vendor: false -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Complete the Uniform",
  "tag": "section",
  "class": "section-complete-uniform",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Complete the Uniform"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wear the principle. Defend the right."
    }
  ],
  "presets": [
    {
      "name": "Complete the Uniform"
    }
  ]
}
{% endschema %}
