{% comment %}
  Principle Library Section – Dynamic & Schema-Driven
  Phase 1 – Aligned to uploaded "The Library of Principles.txt"
  Max 10 historical entries only. Non-partisan. Public domain.
  Usage: Add this section to /pages/the-library and optionally homepage
{% endcomment %}

{% schema %}
{
  "name": "Principle Library",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "The Library of Principles"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro Text",
      "default": "Timeless voices on the freedom to speak. No modern commentary — only ideas that built intellectual courage."
    }
  ],
  "blocks": [
    {
      "type": "principle",
      "name": "Principle Entry",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title + Year",
          "default": "John Milton – Areopagitica (1644)"
        },
        {
          "type": "textarea",
          "id": "intro_text",
          "label": "Intro",
          "default": "Give me the liberty to know, to utter, and to argue freely according to conscience, above all liberties."
        },
        {
          "type": "richtext",
          "id": "excerpt",
          "label": "Excerpt (safe for brand)",
          "default": "<p>Though all the winds of doctrine were let loose to play upon the earth, so truth be in the field, we do injuriously by licensing and prohibiting to misdoubt her strength.</p>"
        },
       {
         "type": "url",
         "id": "full_link",
         "label": "Read Full Text Link"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Principle Library",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="principle-library">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-intro">{{ section.settings.intro }}</p>

    <div class="principles-grid">
      {% for block in section.blocks %}
        <div class="principle-card" {{ block.shopify_attributes }}>
          <h3 class="principle-title">{{ block.settings.title }}</h3>
          <p class="principle-quote">{{ block.settings.intro_text }}</p>
          <div class="principle-excerpt">
            {{ block.settings.excerpt }}
          </div>
          <a href="{{ block.settings.full_link }}" class="read-full" target="_blank" rel="noopener">Read full text →</a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .principle-library { padding: 60px 0; background: #FAF8F3; }
  .section-heading { font-size: 28px; text-align: center; color: #1A2A3A; }
  .section-intro { text-align: center; max-width: 600px; margin: 16px auto 40px; color: #4A4A4A; }
  .principles-grid { display: grid; gap: 32px; max-width: 900px; margin: 0 auto; }
  .principle-card {
    background: white;
    padding: 32px;
    border-radius: 4px;
    border: 1px solid #E8E4DC;
  }
  .principle-title { font-size: 18px; color: #1A2A3A; margin-bottom: 12px; }
  .principle-quote { font-style: italic; color: #3A3A3A; margin-bottom: 16px; }
  .read-full { color: #C4A77D; text-decoration: none; font-size: 13px; }
</style>