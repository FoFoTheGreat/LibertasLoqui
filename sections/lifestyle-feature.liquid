{% comment %}
  sections/lifestyle-feature.liquid
  Libertas Loqui — Lifestyle Feature Section
  Tone: Calm confidence, principle-forward, non-partisan
  Compatible: Dawn OS 2.0+ / Shopify Performance Guardrails 2026
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lifestyle-feature__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .lifestyle-feature__subtitle {
    margin-top: 0.5rem;
    color: rgba(var(--color-foreground), 0.75);
    font-size: calc(var(--font-body-scale) * 1rem);
    line-height: 1.65;
    font-style: italic;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .lifestyle-card {
    display: flex;
    flex-direction: column;
  }

  .lifestyle-card__image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 6px;
    background: rgba(var(--color-foreground), 0.04);
  }

  .lifestyle-card__caption {
    margin-top: 0.75rem;
    color: rgba(var(--color-foreground), 0.78);
    font-size: calc(var(--font-body-scale) * 0.92rem);
    line-height: 1.5;
    text-align: center;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- unless section.settings.heading == blank -%}
      <div class="lifestyle-feature__header">
        <h2 class="inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- unless section.settings.subheading == blank -%}
          <p class="lifestyle-feature__subtitle">{{ section.settings.subheading }}</p>
        {%- endunless -%}
      </div>
    {%- endunless -%}

    <div class="grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down">
      {%- for block in section.blocks -%}
        <div class="grid__item lifestyle-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w"
              sizes="(max-width: 749px) 100vw, (max-width: 999px) 50vw, 33vw"
              alt="{{ block.settings.alt_text | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="lifestyle-card__image"
            >
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <p class="lifestyle-card__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="center" style="margin-top: 2.5rem;">
        <a href="{{ section.settings.cta_link }}" class="button">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Lifestyle Feature",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Wear the Principle",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "h2" },
        { "value": "h1", "label": "h1" },
        { "value": "h0", "label": "h0" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "default": "Quiet moments of clear thinking, open dialogue, and intellectual courage.",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "Shop the Collection",
      "label": "CTA Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "default": "/collections/all",
      "label": "CTA Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1",
      "label": "Mobile columns"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64,
      "label": "t:sections.all.padding.padding_top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64,
      "label": "t:sections.all.padding.padding_bottom"
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Lifestyle Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "default": "Libertas Loqui wearer in thoughtful conversation",
          "label": "Alt text"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Optional caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lifestyle Feature",
      "blocks": [
        { "type": "image_block" },
        { "type": "image_block" },
        { "type": "image_block" }
      ]
    }
  ]
}
{% endschema %}