{% style %}
.ll-hero { background: #0a0a0a; color: #f8f8f8; padding: 120px 20px; text-align: center; }
.ll-hero__content { max-width: 800px; margin: 0 auto; }
.ll-hero__title { font-size: 3.2rem; font-weight: 700; line-height: 1.1; margin-bottom: 16px; }
.ll-hero__subtitle { font-size: 1.4rem; opacity: 0.9; margin-bottom: 32px; }
.ll-hero__cta { background: #f8f8f8; color: #0a0a0a; padding: 16px 40px; font-size: 1.1rem; border-radius: 4px; text-decoration: none; display: inline-block; }
{% endstyle %}

<section class="ll-hero">
  <div class="ll-hero__content">
    <h1 class="ll-hero__title">Freedom to Speak</h1>
    <p class="ll-hero__subtitle">Wear the principle. Defend the right.<br>Proudly made in the USA • First Amendment protected.</p>
    <a href="/collections/all" class="ll-hero__cta">Shop the 1A Defender Collection</a>
    <p style="margin-top: 40px; font-size: 0.95rem; opacity: 0.7;">Non-partisan. Thoughtful. Built for clear thinkers.</p>
  </div>
</section>